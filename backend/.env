# ============================================================
# Thai EduData Insight - Backend Environment (Development)
# ============================================================

# ค่าที่ขีดเส้นว่า "← เพิ่มใหม่" คือของที่ขาดไปก่อน


# ───────── App ─────────
APP_ENV=development
APP_SECRET_KEY=dev-secret-change-me
APP_BASE_URL=http://127.0.0.1:3000


# ───────── Database (PostgreSQL) ─────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/datacatalog
DATABASE_POOL_SIZE=10


# ───────── Redis ─────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=


# ───────── MinIO (File Storage) ─────────
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=datacatalog


# ───────── Elasticsearch ─────────
ELASTICSEARCH_URL=http://elasticsearch:9200


# ───────── JWT (Authentication) ─────────
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRE_MINUTES=60


# ───────── SMTP (Email - Mailtrap Dev) ─────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_cWXoCA95_A7GjtQHqTrdB865ZfQ29LMN8
SMTP_FROM_EMAIL=onboarding@resend.dev
SMTP_FROM_NAME=Thai EduData Insight
SMTP_USE_TLS=true


# ───────── Admin Notification ─────────
ADMIN_NOTIFICATION_EMAIL=admin@datacatalog.th


# ───────── Auth - Token Expiry ─────────
VERIFY_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=1


# ───────── Auth - Account Lockout ─────────
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15


# ───────── Auth - Cleanup (Cron Job) ─────────
EMAIL_UNVERIFIED_CLEANUP_DAYS=14


# ───────── Security ─────────
BCRYPT_COST_FACTOR=12


# ───────── Rate Limit ─────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_REGISTER_PER_HOUR=3
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_RESEND_EMAIL_COOLDOWN_SECONDS=60


# ───────── File Upload ─────────
MAX_FILE_SIZE_MB=100
MAX_VERIFICATION_DOC_SIZE_MB=5


# ───────── Email Retry ─────────
EMAIL_RETRY_MAX_ATTEMPTS=3
EMAIL_RETRY_BACKOFF_MINUTES=1,5,30


# ───────── Cloudflare Turnstile ─────────
TURNSTILE_SECRET_KEY=0x4AAAAAADjB8ZPtGLDMNEtfi2RAOV9jg0Q
TURNSTILE_ENABLED=false

# ───────── CORS ─────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001